rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Hostella — правила доступа Firestore (именованная БД "hostella").
//
// ВАЖНО ОБ АРХИТЕКТУРЕ:
//   Сейчас приложение использует анонимный вход (signInAnonymously), а проверка
//   логина/пароля и ролей выполняется НА КЛИЕНТЕ. Поэтому на уровне правил можно
//   различить только «есть анонимная сессия / нет». Это НЕ защищает данные от
//   технически подкованного пользователя: любой, у кого есть публичный конфиг
//   Firebase (он в бандле), может пройти анонимную аутентификацию и получить
//   доступ к данным в обход UI.
//
//   Настоящая защита требует миграции на реальную аутентификацию (Firebase Auth
//   email/пароль или кастомные claims) и проверки ролей ЗДЕСЬ, в правилах.
//   До миграции эти правила лишь:
//     • закрывают базу от полностью анонимного (без sign-in) доступа и «test mode»;
//     • запрещают любой доступ вне рабочего пути artifacts/hostella-multi-v4.
//
//   Разверните: firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Рабочие данные приложения.
    match /artifacts/hostella-multi-v4/public/data/{document=**} {
      allow read, write: if signedIn();
    }

    // Всё остальное — запрещено по умолчанию.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
