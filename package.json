{
  "name": "hostella-desktop",
  "private": true,
  "version": "0.8.4",
  "description": "Hostella Management System",
  "author": "Fazliddin Gulomov",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "node scripts/kill-dev.js && concurrently -k \"cross-env BROWSER=none npm run react-start\" \"npm run electron-start\"",
    "react-start": "vite",
    "electron-start": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:electron": "vite build --config vite.electron.config.js",
    "clean": "npx rimraf release",
    "dist": "npm run clean && npm run build:electron && electron-builder build --publish always",
    "deploy": "npm run build && firebase deploy --only hosting"
  },
  "build": {
    "appId": "com.hostella.app",
    "productName": "Hostella",
    "copyright": "Copyright © 2026",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "gulomovff-lgtm",
        "repo": "hostella-desktop"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/ic.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hostella",
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@sentry/react": "^10.54.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "firebase": "^11.0.0",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.16",
    "wait-on": "^7.0.0"
  }
}
